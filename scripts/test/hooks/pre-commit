#!/bin/bash
# Pre-commit hook: Run quick tests before commit
# Install with: make test-hooks

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${YELLOW}🧪 Running pre-commit tests...${NC}"
echo ""

# Change to repository root
cd "$(git rev-parse --show-toplevel)"

# Run quick tests (unit tests only, <30 seconds)
./scripts/test/run_quick_tests.sh

TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
    echo ""
    echo -e "${RED}❌ Tests failed! Commit aborted.${NC}"
    echo ""
    echo "Options:"
    echo "  1. Fix the failing tests"
    echo "  2. Skip hook: git commit --no-verify (not recommended)"
    echo ""
    exit 1
fi

echo ""
echo -e "${GREEN}✅ Pre-commit tests passed! Proceeding with commit...${NC}"
echo ""
exit 0
