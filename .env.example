# LiveTranslator Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# REQUIRED - minimum to get started
# ============================================================

# Database (generate a strong password)
POSTGRES_DB=livetranslator
POSTGRES_USER=lt_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/5

# JWT authentication (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME
JWT_EXPIRE_MIN=43200

# OpenAI - used for STT (Whisper) and MT (GPT-4o-mini) fallback
OPENAI_API_KEY=sk-...

# ============================================================
# OPTIONAL - better quality with additional providers
# ============================================================

# Domain (for CORS and OAuth redirects)
DOMAIN=localhost

# --- Speech-to-Text Providers ---

# Speechmatics (recommended for Polish & English streaming)
SPEECHMATICS_API_KEY=
SPEECHMATICS_REGION=eu2

# Google Cloud Speech v2 (recommended for Arabic)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=eu

# Deepgram Nova-3 (fast English, budget tier)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Soniox (budget tier)
SONIOX_API_KEY=

# --- Machine Translation Providers ---

# DeepL (recommended for European languages)
DEEPL_API_KEY=

# Google Cloud Translation
GOOGLE_TRANSLATE_API_KEY=

# Amazon Translate
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Google OAuth (for "Sign in with Google") ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ============================================================
# TUNING - adjust to taste
# ============================================================

# STT modes: "local" (free, Whisper in container) or "openai_chunked" (better quality)
LT_STT_PARTIAL_MODE=openai_chunked
LT_STT_FINAL_MODE=openai_chunked

# MT modes: "local" (free, Polish<->English only) or "openai" (all languages)
LT_MT_MODE=openai
LT_MT_MODE_PARTIAL=local
LT_MT_MODE_FINAL=openai

# OpenAI models
OPENAI_STT_MODEL=whisper-1
OPENAI_MT_MODEL=gpt-4o-mini

# Local Whisper settings
WHISPER_MODEL=base
CHUNK_MS=400
NUM_THREADS=4

# Room cleanup (seconds)
ROOM_CLEANUP_INTERVAL=300
ADMIN_ABSENT_THRESHOLD=1800
